generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // 🚀 URL IS REMOVED FROM HERE FOR PRISMA 7
}

model Report {
  id             String   @id @default(cuid())
  domain         String
  type           String
  severity       String
  description    String
  verifications  Int      @default(0)
  createdAt      DateTime @default(now())
}